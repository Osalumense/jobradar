# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (asyncpg-compatible)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# ── AI / Embeddings ────────────────────────────────────────────────────────────
# Google Gemini API key — used for semantic scoring and application material generation
# Free tier: 15 requests/min  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Job Queue / Deduplication ──────────────────────────────────────────────────
# Upstash Redis REST credentials — used for O(1) job deduplication
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Resend API key — https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_your_resend_api_key

# Email address that receives job match alerts
ALERT_TO_EMAIL=you@example.com

# Sender address — use onboarding@resend.dev for testing without a custom domain
ALERT_FROM_EMAIL=JobRadar AI <onboarding@resend.dev>

# ── URLs ───────────────────────────────────────────────────────────────────────
# Public frontend URL — used in password-reset emails
FRONTEND_URL=http://localhost:3078

# Internal backend URL used by the Nuxt frontend container to reach the API
# Keep as-is for Docker Compose; change to your deployed URL in production
SCORER_API_URL=http://backend:9089
